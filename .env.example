# ============================================================
# FLUCORE — Variables de entorno
# Copiar a:
#   apps/web/.env.local   (Next.js)
#   apps/api/.env         (Hono)
# NUNCA commitear los archivos .env / .env.local reales
# ============================================================

# --- Supabase compartidas ---
SUPABASE_URL=https://[proyecto].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NUNCA exponer al cliente browser

# --- Solo backend Hono (apps/api/.env) ---
DATABASE_URL=postgresql://postgres:[password]@db.[proyecto].supabase.co:5432/postgres
ANTHROPIC_API_KEY=sk-ant-...
PORT=8787
NODE_ENV=development

# --- Solo frontend Next.js (apps/web/.env.local) ---
# Prefijo NEXT_PUBLIC_ = seguro exponerlo en el browser
NEXT_PUBLIC_SUPABASE_URL=https://[proyecto].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_URL=http://localhost:8787

# --- NUNCA en NEXT_PUBLIC_ ni en archivos 'use client' ---
# SUPABASE_SERVICE_ROLE_KEY
# DATABASE_URL
# ANTHROPIC_API_KEY
